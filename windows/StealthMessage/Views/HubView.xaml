<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="StealthMessage.Views.HubView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Margin="32,32,32,32"
                    HorizontalAlignment="Center" Spacing="24">

            <!-- Identity card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8D4;" />
                        <TextBlock Text="{Binding Alias}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock Text="Your fingerprint (verify out of band with peers):"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="{Binding Fingerprint}"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True" />
                    <Button Content="Copy fingerprint"
                            Command="{Binding CopyFingerprintCommand}" />
                </StackPanel>
            </Border>

            <!-- Two-column action area -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Host section -->
                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Act as host"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Your peers connect to you."
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding IsHostRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                        <!-- Running status -->
                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    Visibility="{Binding IsHostRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Ellipse Width="8" Height="8" Fill="Green" VerticalAlignment="Center" />
                            <TextBlock Text="Server is running"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="Green" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Content="Start server"
                                Style="{ThemeResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding HostCommand}"
                                Visibility="{Binding IsHostRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                        <Button Content="Resume server"
                                HorizontalAlignment="Stretch"
                                Command="{Binding HostCommand}"
                                Visibility="{Binding IsHostRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <!-- Join section -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Join a room"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />

                        <!-- Connected status + resume -->
                        <StackPanel Spacing="8"
                                    Visibility="{Binding IsJoinConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8" Fill="Green" VerticalAlignment="Center" />
                                <TextBlock Text="Connected"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="Green" VerticalAlignment="Center" />
                            </StackPanel>
                            <Button Content="Resume chat"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ResumeJoinCommand}" />
                        </StackPanel>

                        <!-- Connect form (shown when not connected) -->
                        <StackPanel Spacing="12"
                                    Visibility="{Binding IsJoinConnected, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBox Header="Server address"
                                     PlaceholderText="host:8765 or ws://…"
                                     Text="{Binding ServerAddress, Mode=TwoWay}" />
                            <TextBox Header="Room name (optional)"
                                     PlaceholderText="Leave blank to discover"
                                     Text="{Binding RoomId, Mode=TwoWay}" />
                            <Button Content="Find rooms"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding DiscoverRoomsCommand}" />
                            <ProgressRing IsActive="{Binding IsDiscovering}" />
                            <ListView ItemsSource="{Binding AvailableRooms}"
                                      MaxHeight="180"
                                      Visibility="{Binding AvailableRooms.Count,
                                                   Converter={StaticResource CountToVisibilityConverter}}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Id}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding Kind}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                            <TextBlock Text="{Binding Peers}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Button Content="Connect"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding JoinCommand}" />
                        </StackPanel>

                        <InfoBar IsOpen="{Binding ErrorMessage, Converter={StaticResource NotEmptyToBoolConverter}}"
                                 Severity="Error"
                                 Message="{Binding ErrorMessage}" />
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
