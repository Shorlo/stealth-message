<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="StealthMessage.Views.HostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Side panel -->
        <Border Grid.Column="0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Start/Stop server -->
                <StackPanel Grid.Row="0" Margin="12,12,12,0" Spacing="8">
                    <NumberBox x:Name="PortBox" Header="Port"
                               Value="8765" Minimum="1024" Maximum="65535"
                               ValueChanged="PortBox_ValueChanged" />
                    <Button Content="Start server"
                            HorizontalAlignment="Stretch"
                            Style="{ThemeResource AccentButtonStyle}"
                            Command="{Binding StartServerCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    <Button Content="Stop server"
                            HorizontalAlignment="Stretch"
                            Command="{Binding StopServerCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <InfoBar IsOpen="{Binding ErrorMessage, Converter={StaticResource NotEmptyToBoolConverter}}"
                             Severity="Error" Message="{Binding ErrorMessage}" />
                </StackPanel>

                <!-- Rooms -->
                <Expander Grid.Row="1" Header="Rooms" IsExpanded="True"
                          HorizontalAlignment="Stretch" Margin="12,8,12,0">
                    <StackPanel Spacing="6">
                        <TextBox PlaceholderText="Room name"
                                 Text="{Binding NewRoomName, Mode=TwoWay}" />
                        <ComboBox SelectedItem="{Binding NewRoomKind, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <x:String>1to1</x:String>
                            <x:String>group</x:String>
                        </ComboBox>
                        <Button Content="Add room" HorizontalAlignment="Stretch"
                                Command="{Binding AddRoomCommand}" />
                        <ListView ItemsSource="{Binding Rooms}"
                                  SelectedItem="{Binding SelectedRoom, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Expander>

                <!-- Connected peers -->
                <Expander Grid.Row="2" Header="Connected peers" IsExpanded="True"
                          HorizontalAlignment="Stretch" Margin="12,8,12,0">
                    <ListView x:Name="PeersListView"
                              ItemsSource="{Binding ConnectedPeers}"
                              SelectionChanged="PeersListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Alias}"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{Binding Fingerprint}"
                                               FontFamily="Consolas" FontSize="10"
                                               TextWrapping="Wrap"
                                               IsTextSelectionEnabled="True" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Expander>

                <!-- Context buttons for selected peer -->
                <StackPanel Grid.Row="3" Margin="12,4,12,0" Spacing="4"
                            Orientation="Horizontal"
                            Visibility="{Binding SelectedItem, ElementName=PeersListView,
                                         Converter={StaticResource NotNullToVisibilityConverter}}">
                    <Button Content="Kick" Padding="8,4"
                            Click="KickButton_Click" />
                </StackPanel>

                <!-- Pending approvals -->
                <Expander Grid.Row="4" Header="Pending approvals" IsExpanded="True"
                          HorizontalAlignment="Stretch" Margin="12,8,12,8"
                          Visibility="{Binding PendingPeers.Count,
                                       Converter={StaticResource CountToVisibilityConverter}}">
                    <ListView x:Name="PendingListView" ItemsSource="{Binding PendingPeers}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Alias}"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{Binding Room}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Content="Approve" Padding="6,2" FontSize="11"
                                                Style="{ThemeResource AccentButtonStyle}"
                                                Click="ApproveButton_Click"
                                                Tag="{Binding}" />
                                        <Button Content="Deny" Padding="6,2" FontSize="11"
                                                Click="DenyButton_Click"
                                                Tag="{Binding}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Expander>
            </Grid>
        </Border>

        <!-- Main chat area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Active room header -->
            <Border Grid.Row="0" Padding="16,8"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding SelectedRoom}"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
            </Border>

            <!-- Message log -->
            <ListView Grid.Row="1" ItemsSource="{Binding Messages}" Padding="16,8,16,8">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Input row -->
            <Grid Grid.Row="2" Padding="12" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         PlaceholderText="Type a message…"
                         Text="{Binding MessageInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="MessageBox_KeyDown" />
                <Button Grid.Column="1" Content="Send"
                        Style="{ThemeResource AccentButtonStyle}"
                        Command="{Binding SendMessageCommand}" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
