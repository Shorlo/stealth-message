<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="StealthMessage.Views.JoinView"
    x:Name="JoinViewRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Side panel -->
        <Border Grid.Column="0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12" Spacing="12">

                    <!-- Back to Hub -->
                    <Button Content="← Hub" Padding="8,4" HorizontalAlignment="Left"
                            Click="BackButton_Click" />

                    <!-- Connect form -->
                    <TextBox Header="Server (host:port)"
                             PlaceholderText="e.g. 192.168.1.1:8765"
                             Text="{Binding ServerUri, Mode=TwoWay}"
                             IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNegationConverter}}" />
                    <TextBox Header="Room"
                             PlaceholderText="Room name"
                             Text="{Binding RoomId, Mode=TwoWay}"
                             IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNegationConverter}}" />
                    <Button Content="Connect"
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ConnectCommand}"
                            Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    <Button Content="Disconnect"
                            HorizontalAlignment="Stretch"
                            Command="{Binding DisconnectCommand}"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <InfoBar IsOpen="{Binding ErrorMessage, Converter={StaticResource NotEmptyToBoolConverter}}"
                             Severity="Error" Message="{Binding ErrorMessage}" />

                    <!-- Peer fingerprint -->
                    <Border Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding PeerAlias}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Fingerprint:"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Text="{Binding PeerFingerprint}"
                                       FontFamily="Consolas" FontSize="10"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True" />
                        </StackPanel>
                    </Border>

                    <!-- Group peers -->
                    <Expander Header="Peers in room"
                              Visibility="{Binding Peers.Count, Converter={StaticResource CountToVisibilityConverter}}"
                              HorizontalAlignment="Stretch">
                        <ListView ItemsSource="{Binding Peers}" MaxHeight="200">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Alias}"
                                                   Style="{ThemeResource BodyTextBlockStyle}" />
                                        <TextBlock Text="{Binding Fingerprint}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   TextWrapping="Wrap"
                                                   IsTextSelectionEnabled="True" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>

                    <!-- Available rooms — shown when connected; updated via roomlist frames
                         and a full QueryRoomsAsync on connect.  Current room is filtered out. -->
                    <Expander Visibility="{Binding AvailableRooms.Count,
                                           Converter={StaticResource CountToVisibilityConverter}}"
                              IsExpanded="True"
                              HorizontalAlignment="Stretch">
                        <Expander.Header>
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Switch room"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="↻"
                                        FontSize="14"
                                        Padding="6,2"
                                        ToolTipService.ToolTip="Refresh room list"
                                        Command="{Binding DataContext.RefreshRoomsCommand,
                                                  ElementName=JoinViewRoot}" />
                            </Grid>
                        </Expander.Header>
                        <ListView ItemsSource="{Binding AvailableRooms}"
                                  MaxHeight="200" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="8" Padding="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding}"
                                                   VerticalAlignment="Center"
                                                   Style="{ThemeResource BodyTextBlockStyle}" />
                                        <Button Grid.Column="1"
                                                Content="Switch"
                                                Padding="8,4"
                                                Command="{Binding DataContext.SwitchRoomCommand,
                                                          ElementName=JoinViewRoot}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Pending overlay -->
            <Grid Grid.Row="0" Grid.RowSpan="2"
                  Visibility="{Binding IsPending, Converter={StaticResource BoolToVisibilityConverter}}"
                  Background="{ThemeResource LayerFillColorDefaultBrush}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <ProgressRing IsActive="True" Width="48" Height="48" />
                    <TextBlock Text="Waiting for host approval…"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Message log — ItemsRepeater + ScrollViewer avoids ListView re-virtualization
                 flicker when ScrollIntoView is called after each new message. -->
            <ScrollViewer Grid.Row="0" x:Name="MessageScroller"
                          Padding="16,8"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsPending, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <ItemsRepeater ItemsSource="{Binding Messages}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Input -->
            <Grid Grid.Row="1" Padding="12" ColumnSpacing="8"
                  Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         PlaceholderText="Type a message…"
                         Text="{Binding MessageInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="MessageBox_KeyDown" />
                <Button Grid.Column="1" Content="Send"
                        Style="{ThemeResource AccentButtonStyle}"
                        Command="{Binding SendMessageCommand}" />
            </Grid>
        </Grid>

    </Grid>
</UserControl>
