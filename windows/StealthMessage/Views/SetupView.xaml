<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="StealthMessage.Views.SetupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="480" Margin="40,40,40,40"
                    HorizontalAlignment="Center" Spacing="16">

            <!-- Title -->
            <TextBlock Text="Create identity"
                       Style="{ThemeResource TitleLargeTextBlockStyle}" />
            <TextBlock Text="Your RSA-4096 keypair is generated locally and never leaves this device."
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="Wrap" />

            <!-- Alias -->
            <TextBox x:Name="AliasBox"
                     Header="Alias (your display name)"
                     PlaceholderText="e.g. Alice"
                     Text="{Binding Alias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Passphrase -->
            <PasswordBox x:Name="PassBox"
                         Header="Passphrase (min. 8 characters)"
                         PlaceholderText="Enter passphrase"
                         PasswordChanged="PassBox_PasswordChanged" />

            <!-- Confirm passphrase -->
            <PasswordBox x:Name="ConfirmPassBox"
                         Header="Confirm passphrase"
                         PlaceholderText="Repeat passphrase"
                         PasswordChanged="ConfirmPassBox_PasswordChanged" />

            <!-- Error -->
            <InfoBar x:Name="ErrorBar"
                     IsOpen="{Binding ErrorMessage, Converter={StaticResource NotEmptyToBoolConverter}}"
                     Severity="Error"
                     Message="{Binding ErrorMessage}" />

            <!-- Generate button -->
            <Button Content="Create identity"
                    Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding GenerateCommand}"
                    IsEnabled="{Binding IsGenerating, Converter={StaticResource BoolNegationConverter}}" />

            <!-- Progress -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!-- Fingerprint card (shown after generation) -->
            <Border Visibility="{Binding IsComplete, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Your fingerprint — verify out of band"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{Binding Fingerprint}"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True" />
                    <TextBlock Text="Identity created. Opening hub…"
                               Foreground="{ThemeResource SystemColorHighlightBrush}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
